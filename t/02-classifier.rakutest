use Test;
use lib 'lib';
use LLM::Data::ContentTag::Classifier;
use LLM::Data::ContentTag::Tags;

plan 7;

my LLM::Data::ContentTag::Classifier $c .= new(
	:rules(%(
		confidential => <secret classified restricted>,
		technical    => <algorithm database server>,
		creative     => <story poem song>,
	)),
	:restricted('confidential',),
);

subtest 'No rules match — no tags' => {
	plan 1;
	my LLM::Data::ContentTag::Tags $t = $c.classify('A beautiful sunset.');
	is $t.all-tags.elems, 0, 'No tags matched';
};

subtest 'Single rule matches' => {
	plan 2;
	my LLM::Data::ContentTag::Tags $t = $c.classify('Optimise the database query.');
	ok $t.has-tag('technical'), 'Technical detected';
	nok $t.has-tag('confidential'), 'Not confidential';
};

subtest 'Multiple rules match' => {
	plan 2;
	my LLM::Data::ContentTag::Tags $t = $c.classify('Write a story about a database.');
	ok $t.has-tag('creative'), 'Creative detected';
	ok $t.has-tag('technical'), 'Technical detected';
};

subtest 'Restricted tag triggers needs-unrestricted-model' => {
	plan 1;
	my LLM::Data::ContentTag::Tags $t = $c.classify('This is classified information.');
	ok $t.needs-unrestricted-model, 'Restricted content detected';
};

subtest 'Case insensitive' => {
	plan 1;
	my LLM::Data::ContentTag::Tags $t = $c.classify('TOP SECRET CLASSIFIED DATA');
	ok $t.has-tag('confidential'), 'Case insensitive match';
};

subtest 'classify-from-metadata' => {
	plan 2;
	my LLM::Data::ContentTag::Tags $t = $c.classify-from-metadata(%(
		confidential => True,
		technical => False,
	));
	ok $t.has-tag('confidential'), 'Metadata tag set';
	nok $t.has-tag('technical'), 'Metadata tag not set';
};

subtest 'Empty rules classifier' => {
	plan 1;
	my LLM::Data::ContentTag::Classifier $empty .= new;
	my LLM::Data::ContentTag::Tags $t = $empty.classify('Anything at all.');
	is $t.all-tags.elems, 0, 'No rules = no tags';
};
