use Test;
use lib 'lib';
use LLM::Data::ContentTag::Router;
use LLM::Data::ContentTag::Tags;

plan 5;

subtest 'No routes — default backend' => {
	plan 1;
	my LLM::Data::ContentTag::Router $r .= new(:default-backend('cloud-api'));
	my LLM::Data::ContentTag::Tags $t .= new(:tags(%(public => True)));
	is $r.select-backend($t), 'cloud-api', 'Default backend';
};

subtest 'Route matches tag' => {
	plan 1;
	my LLM::Data::ContentTag::Router $r .= new(:default-backend('cloud-api'));
	$r.add-route('local-model', 'confidential');
	my LLM::Data::ContentTag::Tags $t .= new(:tags(%(confidential => True)));
	is $r.select-backend($t), 'local-model', 'Confidential routed to local';
};

subtest 'Route with multiple tags — any match' => {
	plan 1;
	my LLM::Data::ContentTag::Router $r .= new(:default-backend('cloud-api'));
	$r.add-route('local-model', 'confidential', 'restricted');
	my LLM::Data::ContentTag::Tags $t .= new(:tags(%(restricted => True)));
	is $r.select-backend($t), 'local-model', 'Restricted routed to local';
};

subtest 'First route wins' => {
	plan 1;
	my LLM::Data::ContentTag::Router $r .= new(:default-backend('cloud-api'));
	$r.add-route('model-a', 'technical');
	$r.add-route('model-b', 'technical');
	my LLM::Data::ContentTag::Tags $t .= new(:tags(%(technical => True)));
	is $r.select-backend($t), 'model-a', 'First route takes priority';
};

subtest 'Non-matching route skipped' => {
	plan 1;
	my LLM::Data::ContentTag::Router $r .= new(:default-backend('cloud-api'));
	$r.add-route('reasoning-model', 'technical');
	$r.add-route('local-model', 'confidential');
	my LLM::Data::ContentTag::Tags $t .= new(:tags(%(confidential => True)));
	is $r.select-backend($t), 'local-model', 'Skipped technical, matched confidential';
};
