use Test;
use lib 'lib';
use LLM::Data::ContentTag::Tags;

plan 9;

subtest 'Empty tags' => {
	plan 2;
	my LLM::Data::ContentTag::Tags $t .= new;
	is $t.all-tags.elems, 0, 'No tags';
	nok $t.needs-unrestricted-model, 'No restricted model needed';
};

subtest 'Set tags via constructor' => {
	plan 2;
	my LLM::Data::ContentTag::Tags $t .= new(
		:tags(%(confidential => True, draft => True)),
	);
	ok $t.has-tag('confidential'), 'Has confidential';
	ok $t.has-tag('draft'), 'Has draft';
};

subtest 'has-tag returns False for absent' => {
	plan 1;
	my LLM::Data::ContentTag::Tags $t .= new(:tags(%(a => True)));
	nok $t.has-tag('missing'), 'Absent tag returns False';
};

subtest 'all-tags returns only true tags sorted' => {
	plan 1;
	my LLM::Data::ContentTag::Tags $t .= new(
		:tags(%(zebra => True, alpha => True, off => False)),
	);
	is-deeply $t.all-tags.List, ('alpha', 'zebra'), 'True tags sorted, false excluded';
};

subtest 'needs-unrestricted-model with restricted list' => {
	plan 2;
	my LLM::Data::ContentTag::Tags $t .= new(
		:tags(%(confidential => True, public => True)),
		:restricted('confidential',),
	);
	ok $t.needs-unrestricted-model, 'Restricted tag present';

	my LLM::Data::ContentTag::Tags $t2 .= new(
		:tags(%(public => True)),
		:restricted('confidential',),
	);
	nok $t2.needs-unrestricted-model, 'No restricted tags present';
};

subtest 'needs-unrestricted-model — no restricted list' => {
	plan 1;
	my LLM::Data::ContentTag::Tags $t .= new(:tags(%(anything => True)));
	nok $t.needs-unrestricted-model, 'No restricted list = never needs unrestricted';
};

subtest 'to-hash round-trip' => {
	plan 2;
	my LLM::Data::ContentTag::Tags $orig .= new(
		:tags(%(confidential => True, public => False)),
		:restricted('confidential',),
	);
	my %h = $orig.to-hash;
	my LLM::Data::ContentTag::Tags $restored = LLM::Data::ContentTag::Tags.from-hash(%h);
	ok $restored.has-tag('confidential'), 'Tag preserved';
	ok $restored.needs-unrestricted-model, 'Restricted list preserved';
};

subtest 'from-hash with empty data' => {
	plan 1;
	my LLM::Data::ContentTag::Tags $t = LLM::Data::ContentTag::Tags.from-hash({});
	is $t.all-tags.elems, 0, 'Empty hash = no tags';
};

subtest 'Multiple restricted tags' => {
	plan 2;
	my LLM::Data::ContentTag::Tags $t .= new(
		:tags(%(a => True, b => False, c => True)),
		:restricted('a', 'b', 'c'),
	);
	ok $t.needs-unrestricted-model, 'a is restricted and true';
	is $t.all-tags.elems, 2, 'Only true tags listed';
};
